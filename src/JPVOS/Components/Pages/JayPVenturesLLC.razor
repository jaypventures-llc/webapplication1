@page "/jaypventures-llc"
@page "/enterprise"

<div class="page-stack">
    <PageHero Kicker="JayPVentures LLC"
              Title="Enterprise infrastructure authority."
              Description="JayPVentures LLC is the enterprise company responsible for partnership strategy, venture alignment, and infrastructure execution."
              Image="@AssetPaths.JayPVenturesLlc.Hero"
              ImageAlt="JayPVentures LLC enterprise infrastructure visual" />

    <section class="content-section">
        <div class="grid-3">
            <GlassCard Eyebrow="Architecture" Title="Infrastructure architecture" Description="System design, operating models, web infrastructure, and readiness planning." />
            <GlassCard Eyebrow="Governance" Title="Governance" Description="Documentation, review pathways, operating standards, and decision records." />
            <GlassCard Eyebrow="Identity" Title="Identity and security" Description="Authentication posture, access routing, security alignment, and account readiness." />
            <GlassCard Eyebrow="Deployment" Title="Deployment" Description="Hosting paths, release readiness, environment setup, and delivery support." />
            <GlassCard Eyebrow="Operations" Title="Operations" Description="Process alignment, support pathways, package delivery, and implementation continuity." />
            <GlassCard Eyebrow="Enterprise" Title="Opportunity routing" Description="Enterprise inquiries route into scoped review, implementation, or custom work." />
        </div>
    </section>

    <CTASection Title="Route enterprise work through init."
                Description="Use init to connect enterprise requests to architecture, governance, identity, security, deployment, and operations."
                PrimaryCta="Get init"
                PrimaryHref="/pricing"
                SecondaryCta="Route Access"
                SecondaryHref="/access" />
</div>
