@page "/"
@layout HomeLayout

@* init / JPV-OS Access Gateway Homepage — Clean Rebuild *@

<div class="init-home">
  <!-- Cinematic Atmospheric Background -->
  <div class="atmospheric-bg"></div>

  <!-- Sticky Glass Navigation (Consolidated) -->
  <nav class="init-nav glass-nav" aria-label="Main Navigation">
    <div class="nav-content">
      <a class="nav-logo" href="/">init</a>
      <div class="nav-links">
        <a href="/" class="nav-link active">Home</a>
        <a href="/ecosystem" class="nav-link">Ecosystem</a>
        <a href="/access" class="nav-link">Access</a>
        <a href="/pricing" class="nav-link">Pricing</a>
      </div>
      <a href="/access" class="nav-cta">Get init</a>
    </div>
  </nav>

  <!-- Hero Section (Cinematic, Tightened) -->
  <section class="hero">
    <div class="hero-left glass-panel">
      <div class="hero-eyebrow">init &bull; powered by JPV-OS &bull; operated by JayPVentures LLC</div>
      <h1 class="hero-title">Welcome to the Venture</h1>
      <div class="hero-subtitle">
        The unified platform for creators, enterprises, and communities to build, connect, and scale with trust.
      </div>
      <div class="hero-ctas">
        <a href="/access" class="cta-primary">Enter the Ecosystem</a>
        <a href="/ecosystem" class="cta-secondary">Explore Architecture</a>
      </div>
      <div class="metrics trust-metrics">
        <div class="metric-card"><span>Uptime</span><strong>99.99%</strong></div>
        <div class="metric-card"><span>Global Reach</span><strong>52 Regions</strong></div>
        <div class="metric-card"><span>Active Clients</span><strong>14,200+</strong></div>
      </div>
    </div>
    <div class="hero-right">
      <div class="product-visual" aria-label="Premium Platform Visual">
        <div class="slab"></div>
        <div class="slab-glow"></div>
        <div class="slab-aura"></div>
        <div class="slab-ring ring1"></div>
        <div class="slab-ring ring2"></div>
        <div class="slab-ring ring3"></div>
      </div>
    </div>
  </section>


  <!-- Ecosystem Metrics Section (already in hero) -->


  <!-- Access Lanes Section (Grouped, Glass, Icons, State) -->
  <section class="access-lanes-section">
    <h2>Access Lanes</h2>
    <div class="access-lanes product-lanes">
      <div class="lane-card" tabindex="0">
        <span class="lane-icon community"></span>
        <div class="lane-content">
          <div class="lane-title">Community</div>
          <div class="lane-desc">Open access for creators, builders, and early adopters.</div>
        </div>
      </div>
      <div class="lane-card" tabindex="0">
        <span class="lane-icon professional"></span>
        <div class="lane-content">
          <div class="lane-title">Professional</div>
          <div class="lane-desc">Advanced tools and integrations for teams and operators.</div>
        </div>
      </div>
      <div class="lane-card" tabindex="0">
        <span class="lane-icon institutional"></span>
        <div class="lane-content">
          <div class="lane-title">Institutional</div>
          <div class="lane-desc">Enterprise-grade delivery, compliance, and support.</div>
        </div>
      </div>
    </div>
  </section>

