@page "/"
@page "/jpv-os"

<section class="jpv-home jpv-section">
    <div class="jpv-home-layout">
        <div class="jpv-home-copy">
            <div class="jpv-kicker">Infrastructure Operating System</div>
            <h1 class="jpv-title">JPV-OS</h1>
            <p class="jpv-lede">
                JPV-OS aligns identity, infrastructure, governance, access, intelligence,
                creator execution, research validation, and deployment readiness into one
                coordinated operating architecture.
            </p>

            <div class="jpv-home-actions">
                <a class="home-button primary" href="/access">Route Access</a>
                <a class="home-button" href="/partners">View Operating Stack</a>
                <a class="home-button" href="/ventures">View Ventures</a>
            </div>
        </div>

        <div class="jpv-os-brand-media">
            <img src="/assets/jpv-os/jpv-os-hero.png" alt="JPV-OS brand system" />
        </div>
    </div>

    <section class="jpv-home-map">
        <div class="partner-section-label">Operating Layers</div>

        <div class="system-layers">
            <a href="/jaypventures-llc" class="system-layer">
                <strong>JayPVentures LLC</strong>
                <span>Enterprise Infrastructure</span>
            </a>

            <a href="/jaypventures" class="system-layer">
                <strong>jaypventures</strong>
                <span>Creator Ecosystem</span>
            </a>

            <a href="/jaypvlabs" class="system-layer">
                <strong>jaypVLabs</strong>
                <span>Validation Environment</span>
            </a>

            <a href="/jpv-institute" class="system-layer">
                <strong>JPV Institute</strong>
                <span>Research & Doctrine</span>
            </a>

            <a href="/partners" class="system-layer">
                <strong>Partners</strong>
                <span>Operating Stack</span>
            </a>

            <a href="/ventures" class="system-layer">
                <strong>Ventures</strong>
                <span>Packages & Pricing</span>
            </a>
        </div>
    </section>
</section>
