@page "/"
@page "/init"

<div class="page-stack">
    <PageHero Kicker="Home"
              Title="Operational interface for infrastructure authority."
              Description="init is the production gateway for orchestration, governance routing, operational integrity, and venture access across the JPV-OS ecosystem."
              Image="@AssetPaths.Init.Hero"
              ImageAlt="init operational interface" />

    <section class="content-section">
        <SectionHeader Kicker="Orchestration"
                       Title="Route each mission to the right surface."
                       Description="Use focused pathways for commercial routing, partner governance, and infrastructure authority without losing continuity across environments." />

        <div class="access-grid">
            <RouteTile Eyebrow="Commercial"
                       Title="Pricing and access"
                       Description="Move from package selection to access routing with production-ready flows."
                       Href="/pricing" />
            <RouteTile Eyebrow="Partnership"
                       Title="Partner governance"
                       Description="Coordinate platform, cloud, AI, and deployment relationships through one partner surface."
                       Href="/partners" />
            <RouteTile Eyebrow="Authentication"
                       Title="Login routing"
                       Description="Start credential handoff for member, partner, enterprise, and operator pathways."
                       Href="/login" />
            <RouteTile Eyebrow="Operations"
                       Title="Access routing"
                       Description="Direct requests by role while preserving governance controls and operational integrity."
                       Href="/access" />
        </div>
    </section>

    <CTASection Title="Enter init."
                Description="Launch through the production UI shell for governance, routing, and infrastructure authority workflows."
                PrimaryCta="Open pricing"
                PrimaryHref="/pricing"
                SecondaryCta="View partners"
                SecondaryHref="/partners" />
</div>
