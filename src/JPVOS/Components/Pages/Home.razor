
@page "/"
@page "/init"

<div class="home-command">
    <!-- Hero Module -->
    <section class="command-module module-frame asset-panel" id="hero">
        <HeroSection
            Logo="/assets/init/init-hero.png"
            Kicker="Application Interface"
            Headline="Welcome to the venture."
            Subheadline="init is the application interface for the JPV-OS ecosystem."
            Body="We built init to route access, launch ventures, coordinate infrastructure, and connect the full ecosystem through one operational surface."
            PrimaryCta="Get init"
            PrimaryHref="/pricing"
            SecondaryCta="Explore Ecosystem"
            SecondaryHref="/ecosystem"
            Visual="/assets/init/init-hero.png"
            VisualAlt="init application interface preview" />
    </section>

    <!-- Launch Schematic Module -->
    <section class="command-module module-frame schematic-grid" id="launch-schematic">
        <h2 class="module-title">Get init: Launch Schematic</h2>
        <div class="schematic-grid">
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="init schematic" />
                <h3>Application Interface</h3>
                <p>Unified access, launch, and ecosystem routing.</p>
            </div>
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="init schematic" />
                <h3>Venture Launch</h3>
                <p>Launch, package, and grow through defined pathways.</p>
            </div>
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="init schematic" />
                <h3>Partner Ecosystem</h3>
                <p>Technology integrations and partner roles.</p>
            </div>
        </div>
    </section>

    <!-- Ecosystem Routing Module -->
    <section class="command-module module-frame" id="ecosystem-routing">
        <h2 class="module-title">Ecosystem Routing</h2>
        <div class="schematic-grid">
            <a class="route-node" href="/ecosystem">
                <img src="/assets/init/init-hero.png" alt="Ecosystem" />
                <h3>Ecosystem</h3>
                <p>Connect ventures, infrastructure, partners, access, and pricing.</p>
            </a>
            <a class="route-node" href="/access">
                <img src="/assets/init/init-hero.png" alt="Access" />
                <h3>Access</h3>
                <p>Route to member, partner, enterprise, developer, and admin environments.</p>
            </a>
            <a class="route-node" href="/pricing">
                <img src="/assets/init/init-hero.png" alt="Pricing" />
                <h3>Pricing</h3>
                <p>Choose the package path for your next move.</p>
            </a>
        </div>
    </section>

    <!-- Venture Pathways Module -->
    <section class="command-module module-frame" id="venture-pathways">
        <h2 class="module-title">Venture Pathways</h2>
        <div class="schematic-grid">
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="Launches" />
                <h3>Venture Launches</h3>
                <p>Plan launches, campaigns, and offers from one interface.</p>
            </div>
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="Products" />
                <h3>Digital Products</h3>
                <p>Package content, tools, and memberships into clear pathways.</p>
            </div>
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="Creator" />
                <h3>Creator Access</h3>
                <p>Route creators into community, launch support, and memberships.</p>
            </div>
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="Enterprise" />
                <h3>Enterprise</h3>
                <p>Connect architecture, identity, security, and deployment.</p>
            </div>
        </div>
    </section>

    <!-- Partner Preview Module -->
    <section class="command-module module-frame asset-panel" id="partner-preview">
        <h2 class="module-title">Partner Ecosystem Preview</h2>
        <div class="schematic-grid">
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="Microsoft" />
                <h3>Microsoft</h3>
                <p>Platform and infrastructure partner.</p>
            </div>
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="Azure" />
                <h3>Azure</h3>
                <p>Cloud and identity partner.</p>
            </div>
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="Cloudflare" />
                <h3>Cloudflare</h3>
                <p>Edge and connectivity partner.</p>
            </div>
        </div>
        <div class="hero-actions">
            <a class="button secondary" href="/partners">View Partners</a>
        </div>
    </section>

    <!-- Access + Pricing Decision Module -->
    <section class="command-module module-frame decision-panel" id="access-pricing">
        <h2 class="module-title">Access & Pricing</h2>
        <div class="schematic-grid">
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="Member Access" />
                <h3>Member Access</h3>
                <p>Community and member routing for updates, resources, and entry.</p>
                <a class="button primary" href="/access">Go to Access</a>
            </div>
            <div class="route-node">
                <img src="/assets/init/init-hero.png" alt="Pricing" />
                <h3>Pricing</h3>
                <p>Checkout-ready package paths for all roles.</p>
                <a class="button primary" href="/pricing">View Pricing</a>
            </div>
        </div>
    </section>

    <!-- Final CTA Module -->
    <section class="command-module module-frame asset-panel" id="final-cta">
        <CTASection Title="Get init."
                    Description="Start with the application interface we built to connect access, ventures, infrastructure, partners, and pricing."
                    PrimaryCta="Get init"
                    PrimaryHref="/pricing"
                    SecondaryCta="Explore Ecosystem"
                    SecondaryHref="/ecosystem" />
    </section>
</div>
