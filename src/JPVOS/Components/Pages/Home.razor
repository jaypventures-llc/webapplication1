  <section>
    <h2>Platform Compatibility</h2>
    <div class="partner-ecosystem">
      <span class="partner-text">Compatible with:</span>
      <span class="partner-list">Microsoft, GitHub, Cloudflare, Stripe, Discord, OpenAI, Intel, HP, Wix, Azure</span>
    </div>
  </section>

  <section class="architecture-section">
    <h2>Platform Architecture</h2>
    <div class="architecture-layers">
      <div class="arch-layer">Access</div>
      <div class="arch-layer">Identity</div>
      <div class="arch-layer">Payments</div>
      <div class="arch-layer">Community</div>
      <div class="arch-layer">Governance</div>
      <div class="arch-layer">Enterprise Delivery</div>
    </div>
  </section>

  <!-- Governance & Operational Standards Section -->
  <section>
    <h2>Governance &amp; Operational Standards</h2>
    <!-- ... -->
  </section>


  <!-- Founder Vision Section (Premium Card) -->
  <section>
    <h2>Founder Vision</h2>
    <div class="founder-section">
      <div class="founder-card glass-card">
        <div class="founder-portrait">
          <img src="/img/founder-portrait.jpg" alt="Founder Portrait"
               onerror="this.src='/img/founder-placeholder.png';this.classList.add('placeholder');" />
        </div>
        <div class="founder-statement">
          <blockquote>“Our mission is to unify digital infrastructure, empower creators, and enable enterprises to
            operate at scale with trust and intelligence.”</blockquote>
            <div class="founder-signature">— JayPVentures LLC</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
