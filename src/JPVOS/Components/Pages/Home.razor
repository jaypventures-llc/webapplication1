@page "/"

<div class="canva-shell">

    <section class="venture-hero">

        <div class="venture-grid"></div>
        <div class="venture-glow"></div>

        <div class="venture-hero-inner">

            <div class="venture-eyebrow">
                JPV-OS • INFRASTRUCTURE V4.2
            </div>

            <h1 class="venture-title">
                Welcome to the Venture.
            </h1>

            <p class="venture-subtitle">
                Enterprise-grade operating infrastructure for creators,
                partners, and sovereign digital ecosystems.
            </p>

            <div class="venture-actions">
                <a href="/access" class="venture-btn venture-btn-primary">
                    Get init
                </a>

                <a href="/pricing" class="venture-btn venture-btn-secondary">
                    Explore Access
                </a>
            </div>

            <div class="venture-metrics">

                <div class="venture-metric-card">
                    <span class="venture-metric-label">UPTIME</span>
                    <strong>99.99%</strong>
                </div>

                <div class="venture-metric-card">
                    <span class="venture-metric-label">ACTIVE NODES</span>
                    <strong>14,200</strong>
                </div>

                <div class="venture-metric-card">
                    <span class="venture-metric-label">OPERATIONS</span>
                    <strong>847</strong>
                </div>

                <div class="venture-metric-card">
                    <span class="venture-metric-label">REGIONS</span>
                    <strong>52</strong>
                </div>

            </div>

        </div>

    </section>

    <section class="venture-routing">

        <div class="venture-section-label">
            ECOSYSTEM ARCHITECTURE
        </div>

        <h2 class="venture-section-title">
            Operational Routing Layers
        </h2>

        <p class="venture-section-copy">
            Six access lanes engineered for distinct operational contexts
            within the JPV-OS ecosystem.
        </p>

        <div class="venture-routing-grid">

            <div class="venture-routing-card">
                <h3>Member Access</h3>
                <p>Community systems, updates, Discord access routing, and onboarding.</p>
            </div>

            <div class="venture-routing-card">
                <h3>VIP Venture</h3>
                <p>Private infrastructure channels, founder sessions, and VIP coordination.</p>
            </div>

            <div class="venture-routing-card">
                <h3>Creator Lane</h3>
                <p>Creator publishing infrastructure, monetization systems, and deployment tools.</p>
            </div>

            <div class="venture-routing-card">
                <h3>Operator</h3>
                <p>Infrastructure tooling, governance execution, and operational workflows.</p>
            </div>

            <div class="venture-routing-card">
                <h3>Enterprise</h3>
                <p>Enterprise integrations, compliance routing, and orchestration systems.</p>
            </div>

            <div class="venture-routing-card">
                <h3>Sovereign</h3>
                <p>Dedicated ecosystem infrastructure and strategic deployment environments.</p>
            </div>

        </div>

    </section>

</div>
