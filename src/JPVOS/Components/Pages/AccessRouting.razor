@page "/access"
@page "/access-routing"

<section class="jpv-section access-page">
    <div class="jpv-kicker">Access Gateway</div>
    <h1 class="jpv-title">Route the right request to the right operating layer.</h1>
    <p class="jpv-lede">
        Access Gateway routes member access, enterprise requests, creator inquiries,
        partner collaboration, and venture packages through the correct JPV-OS layer.
    </p>

    <div class="package-grid access-package-grid">
        <PackageCard
            Eyebrow="Members"
            Name="Member Access"
            Price="$25"
            Term="monthly"
            Detail="Community and member access for public-facing updates, selected resources, and guided ecosystem entry."
            Features="Member routing|Updates|Community access|Resource path"
            CheckoutUrl="/checkout-not-configured" />

        <PackageCard
            Eyebrow="Partners"
            Name="Partner Intake"
            Price="$0"
            Term="application"
            Detail="Structured intake for enterprise, platform, creator, and institutional collaboration requests."
            Features="Partner form|Routing review|Fit assessment|Next steps"
            CheckoutUrl="/partners" />

        <PackageCard
            Eyebrow="Ventures"
            Name="Packages & Pricing"
            Price="View"
            Term="ventures"
            Detail="Review all public packages, pricing tiers, and checkout options from the centralized Ventures page."
            Features="Enterprise|Creator|Labs|Institute"
            CheckoutUrl="/ventures" />
    </div>
</section>
