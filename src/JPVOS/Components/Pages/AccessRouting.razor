@page "/access"
@page "/access-routing"

<section class="jpv-section access-page">
    <div class="jpv-kicker">Access Gateway</div>
    <h1 class="jpv-title">Route the right request to the right operating layer.</h1>
    <p class="jpv-lede">
        Access Gateway routes member access, enterprise requests, creator inquiries, partner collaboration, and administrative review through the correct JPV-OS layer.
    </p>

    <div class="package-grid">
        <PackageCard Eyebrow="Members" Name="Member Access" Price="$25" Term="monthly" Detail="Community and member access for public-facing updates, selected resources, and guided ecosystem entry." Features="Member routing|Updates|Community access|Resource path" CheckoutUrl="/checkout-not-configured" />
        <PackageCard Eyebrow="Partners" Name="Partner Intake" Price="$0" Term="application" Detail="Structured intake for enterprise, platform, creator, and institutional collaboration requests." Features="Partner form|Routing review|Fit assessment|Next steps" CheckoutUrl="/checkout-not-configured" />
        <PackageCard Eyebrow="Admin" Name="Admin Review" Price="Private" Term="protected" Detail="Protected internal review route for governance, security, infrastructure, and deployment decisions." Features="Governance review|Security review|Deployment review|Protected routing" CheckoutUrl="/checkout-not-configured" />
    </div>
</section>
