@page "/access"
@page "/access-routing"

<div class="page-stack">
    <PageHero Kicker="Access"
              Title="Login and environment routing."
              Description="init routes people into the right access environment: member access, partner portal, enterprise governance, operational authority, and developer workflows."
              Image="@AssetPaths.JpvOs.Core"
              ImageAlt="JPV-OS access routing core visual" />

    <section class="content-section">
        <div class="access-grid">
            <AccessCard Environment="Member" Title="Member Access" Description="Community entry, updates, selected resources, and guided ecosystem movement." Href="/login" />
            <AccessCard Environment="Partner" Title="Partner Governance" Description="Technology ecosystem intake, collaboration review, and routing continuity." Href="/partners" />
            <AccessCard Environment="Enterprise" Title="Infrastructure Authority" Description="Architecture, governance, identity, security, deployment, and operations requests." Href="/jaypventures-llc" />
            <AccessCard Environment="Operations" Title="Operational Integrity" Description="Protected internal pathway for delivery governance, security posture, and release authority." Href="/admin" />
            <AccessCard Environment="Developer" Title="Developer Routing" Description="Development workflow, repositories, automation, runtime tooling, and implementation pathways." Href="/ecosystem" />
            <AccessCard Environment="Support" Title="Support Routing" Description="Support pathways for account, package, access, partner, and implementation requests." Href="/contact" />
        </div>
    </section>

    <CTASection Title="Get init access."
                Description="Start with login routing, then move into the right environment for the next operational step."
                PrimaryCta="Open login"
                PrimaryHref="/login"
                SecondaryCta="Explore Ecosystem"
                SecondaryHref="/ecosystem" />
</div>
