@page "/partners"
@page "/partnerships"

<div class="page-stack">
    <PageHero Kicker="Partners"
              Title="Technology ecosystem integrations."
              Description="These are the partners who have helped support the development of this project. Partner access is routed through JayPVentures LLC for enterprise infrastructure, implementation review, and operational alignment."
              Image="@AssetPaths.References.PartnerBoard"
              ImageAlt="approved partner ecosystem visual reference" />

    <section class="content-section">
        <div class="partner-categories">
            <PartnerCategory Label="Infrastructure" Title="Cloud, identity, and network" Description="Infrastructure services, identity systems, productivity platforms, enterprise systems, and network connectivity." Partners="@InfrastructurePartners" />
            <PartnerCategory Label="Development" Title="Engineering and AI" Description="Source workflows, editor systems, AI assistance, runtime tooling, and automation support." Partners="@DevelopmentPartners" />
            <PartnerCategory Label="Access" Title="Payments and community" Description="Commerce, community access, web publishing, public routing, and workspace coordination." Partners="@AccessPartners" />
            <PartnerCategory Label="Operating" Title="Hardware and production" Description="Hardware, compute, operating systems, creative continuity, and real-time production environment." Partners="@OperatingPartners" />
            <PartnerCategory Label="Research" Title="Education and knowledge" Description="Learning, academic development, professional education, and production knowledge systems." Partners="@ResearchPartners" />
        </div>
    </section>
</div>

