@page "/pricing"
@page "/packages"

<div class="page-stack">
    <PageHero Kicker="Pricing"
              Title="Packages and checkout-ready cards."
              Description="init keeps the commercial paths visible: member access, creator launch, partner package, enterprise infrastructure, and custom implementation."
              Image="@AssetPaths.Init.Hero"
              ImageAlt="init package and access interface visual" />

    <section class="content-section">
        <div class="pricing-toggle">
            <button class="toggle-btn @(annual ? "" : "active")" @onclick="() => annual = false">Monthly</button>
            <button class="toggle-btn @(annual ? "active" : "")" @onclick="() => annual = true">Annual <span class="toggle-save">(2 months free)</span></button>
        </div>
        <div class="pricing-grid">
            @foreach (var pkg in Packages)
            {
                if (pkg.Key == "member_access" || pkg.Key == "creator_launch")
                {
                    <PricingCard
                        Eyebrow="@pkg.Eyebrow"
                        Name="@pkg.Name"
                        Price="@GetPrice(pkg)"
                        Term="@GetTerm(pkg)"
                        Description="@pkg.Description"
                        Features="@pkg.Features"
                        Cta="Get init"
                        OnCheckout="() => StartCheckout(GetPackageKey(pkg), GetTerm(pkg))" />
                }
                else if (pkg.Key == "partner_package")
                {
                    <PricingCard
                        Eyebrow="@pkg.Eyebrow"
                        Name="@pkg.Name"
                        Price="@GetPrice(pkg)"
                        Term="@GetTerm(pkg)"
                        Description="@pkg.Description"
                        Features="@pkg.Features"
                        Cta="Request partner access"
                        IsDisabled="true" />
                }
                else if (pkg.Key == "enterprise_infrastructure")
                {
                    <PricingCard
                        Eyebrow="@pkg.Eyebrow"
                        Name="@pkg.Name"
                        Price="@GetPrice(pkg)"
                        Term="@GetTerm(pkg)"
                        Description="@pkg.Description"
                        Features="@pkg.Features"
                        Cta="Request enterprise package"
                        IsDisabled="true" />
                }
                else if (pkg.Key == "custom_implementation")
                {
                    <PricingCard
                        Eyebrow="@pkg.Eyebrow"
                        Name="@pkg.Name"
                        Price="@GetPrice(pkg)"
                        Term="@GetTerm(pkg)"
                        Description="@pkg.Description"
                        Features="@pkg.Features"
                        Cta="Contact for quote"
                        IsDisabled="true" />
                }
            }
        </div>
    </section>

    <CTASection Title="Get init."
                Description="Choose the package path that fits the next move, then route into the right access environment."
                PrimaryCta="Get init"
                PrimaryHref="/pricing"
                SecondaryCta="Route Access"
                SecondaryHref="/access" />
</div>

@code {
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    private bool annual = false;

    private record Package(
        string Key,
        string Eyebrow,
        string Name,
        string Description,
        string[] Features,
        int Monthly,
        int Annual,
        string Access,
        string DiscordRole
    );

    private Package[] Packages = new[]
    {
        new Package("member_access", "Member", "Member Access", "Discord member role, updates, resource access", new[]{"Discord role","Updates","Resource access"}, 20, 200, "/access", "community"),
        new Package("creator_launch", "Creator", "Creator Launch", "Creator role, launch resources, venture support", new[]{"Creator role","Launch resources","Venture support"}, 99, 990, "/access", "vip"),
        new Package("partner_package", "Partner", "Partner Package", "Partner role, partner portal access", new[]{"Partner role","Partner portal"}, 199, 1990, "/partners", "partner"),
        new Package("enterprise_infrastructure", "Enterprise", "Enterprise Infrastructure", "Enterprise role, implementation intake, private access", new[]{"Enterprise role","Implementation intake","Private access"}, 999, 9990, "/access", "enterprise"),
        new Package("custom_implementation", "Custom", "Custom Implementation", "Manual quote, scoped delivery", new[]{"Manual quote","Scoped delivery"}, 4999, 0, "/contact", "custom")
    };

    private string GetPrice(Package pkg) => pkg.Key == "custom_implementation"
        ? annual ? "Custom" : "$4,999+"
        : annual ? $"${pkg.Annual}" : $"${pkg.Monthly}";

    private string GetTerm(Package pkg) => pkg.Key == "custom_implementation"
        ? annual ? "custom" : "one-time"
        : annual ? "annual" : "monthly";

    private string GetPackageKey(Package pkg)
    {
        return pkg.Key switch
        {
            "member_access" => "community",
            "creator_launch" => "vip",
            _ => pkg.Key
        };
    }

    private async Task StartCheckout(string packageKey, string interval)
    {
        var response = await Http.PostAsJsonAsync("/api/checkout/create", new { packageKey, interval });
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<CheckoutResult>();
            if (!string.IsNullOrEmpty(result?.url))
            {
                NavigationManager.NavigateTo(result.url, forceLoad: true);
            }
        }
    }

    private class CheckoutResult { public string? url { get; set; } }
}
