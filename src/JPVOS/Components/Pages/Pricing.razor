@page "/pricing"
@page "/packages"
@using JPVOS.Services

<div class="public-page page-stack">
    <section class="public-hero" style="min-height: auto; padding: clamp(60px, 8vh, 100px) clamp(24px, 5vw, 80px);">
        <div class="public-hero-content">
            <p class="public-eyebrow">Pricing</p>
            <h1 class="public-title" style="font-size: clamp(2.2rem, 5vw, 3.5rem);">Packages built around outcomes</h1>
            <p class="public-subtitle">
                Choose the access path that fits what you are trying to activate: member entry, creator launch, partner routing, enterprise infrastructure, or a custom implementation.
            </p>
        </div>
    </section>

    <section class="public-section">
        <div class="public-toggle pricing-toggle">
            <button class="toggle-btn @(annual ? "" : "active")" @onclick="() => annual = false">Monthly</button>
            <button class="toggle-btn @(annual ? "active" : "")" @onclick="() => annual = true">Annual <span class="toggle-save">(2 months free)</span></button>
        </div>

        <div class="public-pricing-grid pricing-grid">
            @foreach (var pkg in Packages)
            {
                <div class="public-pricing-card pricing-card">
                    <span class="card-eyebrow">@pkg.Eyebrow</span>
                    <h3>@pkg.Name</h3>
                    <div class="price-line">
                        <strong>@GetPrice(pkg)</strong>
                        <span>@GetTerm(pkg)</span>
                    </div>
                    <p>@pkg.Description</p>
                    <div class="feature-list">
                        @foreach (var feature in pkg.Features)
                        {
                            <span>@feature</span>
                        }
                    </div>
                    @if (IsDisabled(pkg))
                    {
                        <a href="@pkg.Access" class="button public-btn public-btn-secondary public-btn-full">@GetCta(pkg)</a>
                    }
                    else
                    {
                        <a href="@GetCheckoutUrl(pkg)" class="button public-btn public-btn-primary public-btn-full">@GetCta(pkg)</a>
                    }
                </div>
            }
        </div>
    </section>

    <section class="public-section" style="text-align: center;">
        <div class="public-section-header">
            <h2 class="public-title" style="font-size: clamp(1.8rem, 4vw, 2.5rem);">Start with the path that matches your next move</h2>
            <p class="public-subtitle" style="margin: 0 auto 32px;">
                init keeps access, packages, and operational routing connected so users are not dropped into disconnected links or unclear handoffs.
            </p>
        </div>
        <div class="public-hero-actions">
            <a href="/access" class="public-btn public-btn-primary">Enter access gateway</a>
            <a href="/contact" class="public-btn public-btn-secondary">Contact for fit</a>
        </div>
    </section>
</div>

@code {
    [Inject] private WixCheckoutConfig WixConfig { get; set; } = default!;

    private bool annual = false;

    private record Package(
        string Key,
        string Eyebrow,
        string Name,
        string Description,
        string[] Features,
        int Monthly,
        int Annual,
        string Access,
        string DiscordRole
    );

    private Package[] Packages = new[]
    {
        new Package(
            "member_access",
            "Member",
            "Member Access",
            "Structured access to updates, resources, and ecosystem routing without scattered links or disconnected channels.",
            new[] { "Updates", "Resource access", "Member routing", "Community entry" },
            20,
            200,
            "/access",
            "community"
        ),
        new Package(
            "creator_launch",
            "Creator",
            "Creator Launch",
            "Launch creator-facing projects with access routing, resource packaging, venture support, and community activation.",
            new[] { "Creator role", "Launch resources", "Venture support", "Community access" },
            99,
            990,
            "/access",
            "vip"
        ),
        new Package(
            "partner_package",
            "Partner",
            "Partner Package",
            "Coordinate partnership visibility, implementation review, and operational delivery through the JayPVentures LLC infrastructure pathway.",
            new[] { "Partner role", "Partner portal", "Implementation review", "Operational alignment" },
            199,
            1990,
            "/partners",
            "partner"
        ),
        new Package(
            "enterprise_infrastructure",
            "Enterprise",
            "Enterprise Infrastructure",
            "Private infrastructure alignment for larger implementation needs, enterprise access paths, and structured operational review.",
            new[] { "Enterprise role", "Private access", "Implementation intake", "Infrastructure review" },
            999,
            9990,
            "/access",
            "enterprise"
        ),
        new Package(
            "custom_implementation",
            "Custom",
            "Custom Implementation",
            "Scoped buildout for tailored workflows, access systems, integrations, deployment support, and operational launch requirements.",
            new[] { "Manual quote", "Scoped delivery", "Workflow design", "Deployment support" },
            4999,
            0,
            "/contact",
            "custom"
        )
    };

    private string GetPrice(Package pkg) => pkg.Key == "custom_implementation"
        ? annual ? "Custom" : "$4,999+"
        : annual ? $"${pkg.Annual}" : $"${pkg.Monthly}";

    private string GetTerm(Package pkg) => pkg.Key == "custom_implementation"
        ? annual ? "custom" : "one-time"
        : annual ? "annual" : "monthly";

    private string GetPackageKey(Package pkg)
    {
        return pkg.Key switch
        {
            "member_access" => "community",
            "creator_launch" => "vip",
            _ => pkg.Key
        };
    }

    private string GetCheckoutUrl(Package pkg)
    {
        var packageKey = GetPackageKey(pkg);
        var interval = GetTerm(pkg);
        return WixConfig.GetCheckoutUrl(packageKey, interval);
    }

    private string GetCta(Package pkg)
    {
        return pkg.Key switch
        {
            "member_access" => "Get init",
            "creator_launch" => "Get init",
            "partner_package" => "Request partner access",
            "enterprise_infrastructure" => "Request enterprise package",
            "custom_implementation" => "Contact for quote",
            _ => "Get init"
        };
    }

    private bool IsDisabled(Package pkg)
    {
        return pkg.Key == "partner_package"
            || pkg.Key == "enterprise_infrastructure"
            || pkg.Key == "custom_implementation";
    }
}
