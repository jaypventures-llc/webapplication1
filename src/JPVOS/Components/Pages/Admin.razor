@page "/admin"
@page "/admin-operations"

<div class="page-stack">
    <PageHero Kicker="Admin"
              Title="Governance and operational integrity."
              Description="Admin operations provide infrastructure authority for system governance, validation layer management, structured execution oversight, and operational integrity across the JPV-OS ecosystem."
              Image="@AssetPaths.JayPVenturesLlc.Hero"
              ImageAlt="Admin operations governance visual" />

    <section class="content-section">
        <SectionHeader Kicker="Operational Framework"
                       Title="System governance through operational integrity."
                       Description="Admin operations manage the validation layer that ensures structured execution, architectural alignment, and governance requirements across all ecosystem routes." />
        <div class="grid-3">
            <GlassCard Eyebrow="Validation" Title="Governance layer" Description="System review, policy alignment, execution standards, and operational compliance documentation." />
            <GlassCard Eyebrow="Infrastructure" Title="Infrastructure authority" Description="System architecture, deployment validation, infrastructure readiness, and technical governance decisions." />
            <GlassCard Eyebrow="Routing" Title="Access orchestration" Description="Route validation, access logic, operational routing alignment, and governance routing pathways." />
            <GlassCard Eyebrow="Execution" Title="Structured execution" Description="Process workflows, execution checklists, delivery pathways, and operational continuity assurance." />
            <GlassCard Eyebrow="Integrity" Title="Operational integrity" Description="System health monitoring, compliance verification, integrity checks, and operational readiness." />
            <GlassCard Eyebrow="Authority" Title="Decision framework" Description="Review pathways, decision records, governance authority, and escalation procedures." />
        </div>
    </section>

    <section class="content-section">
        <SectionHeader Kicker="Access Routes"
                       Title="Admin environment routing."
                       Description="Admin operations are restricted to governance and infrastructure authority roles within the JPV-OS access framework." />
        <div class="access-grid">
            <AccessCard Environment="Governance" Title="Governance Review" Description="System governance, policy review, compliance documentation, and decision records." Href="/access" />
            <AccessCard Environment="Operations" Title="Operations Center" Description="Infrastructure authority, operational oversight, validation management, and execution monitoring." Href="/access" />
            <AccessCard Environment="Infrastructure" Title="Infrastructure Authority" Description="Architecture decisions, deployment authority, infrastructure validation, and technical governance." Href="/access" />
        </div>
    </section>

    <CTASection Title="Request admin access."
                Description="Admin operations are governed through structured access requests and governance review."
                PrimaryCta="Request Access"
                PrimaryHref="/access"
                SecondaryCta="Explore Ecosystem"
                SecondaryHref="/ecosystem" />
</div>
