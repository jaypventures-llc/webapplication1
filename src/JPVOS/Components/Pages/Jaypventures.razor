@page "/jaypventures"
@page "/creator"

<div class="page-stack">
    <PageHero Kicker="jaypventures"
              Title="Creator-facing venture ecosystem."
              Description="jaypventures connects creator-facing influence, products, community access, and market activation."
              Image="@AssetPaths.JayPVentures.Hero"
              ImageAlt="jaypventures creator ecosystem visual" />

    <section class="content-section">
        <div class="grid-3">
            <GlassCard Eyebrow="Community" Title="Community pathways" Description="Member updates, public engagement, creator access, and audience movement." />
            <GlassCard Eyebrow="Launches" Title="Creator launches" Description="Campaign direction, offer packaging, product positioning, and launch surfaces." />
            <GlassCard Eyebrow="Memberships" Title="Membership access" Description="Member experiences, recurring access, digital resources, and community routes." />
            <GlassCard Eyebrow="Products" Title="Digital products" Description="Creator products, guides, offers, and checkout-ready packages." />
            <GlassCard Eyebrow="Access" Title="Creator access" Description="Routing for creators who need support entering or expanding the ecosystem." />
            <GlassCard Eyebrow="Growth" Title="Venture growth" Description="Ongoing refinement for audience experience, packages, and public venture development." />
        </div>
    </section>

    <CTASection Title="Build the creator path through init."
                Description="Use init to connect creator access, launches, memberships, products, and pricing."
                PrimaryCta="Get init"
                PrimaryHref="/pricing"
                SecondaryCta="View Ventures"
                SecondaryHref="/ventures" />
</div>
