@page "/checkout-not-configured"

<section class="jpv-section checkout-pending-page">
    <div class="jpv-kicker">Checkout Setup</div>
    <h1 class="jpv-title">Checkout is being configured.</h1>
    <p class="jpv-lede">
        Payment processing for this package is being finalized. Stripe Payment Links
        will be activated once checkout configuration is complete.
    </p>

    <div class="checkout-pending-info">
        <div class="pending-card">
            <h3>Pending Configuration</h3>
            <p>This checkout route is not yet active. Package pricing is displayed on the Ventures page for reference.</p>
        </div>

        <div class="pending-card">
            <h3>Stripe Integration</h3>
            <p>Live checkout will use Stripe Payment Links for secure payment processing and subscription management.</p>
        </div>

        <div class="pending-card">
            <h3>Contact for Access</h3>
            <p>For immediate access or custom arrangements, please use the Contact form or Partner Intake process.</p>
        </div>
    </div>

    <div class="checkout-pending-actions">
        <a class="home-button primary" href="/ventures">View Packages</a>
        <a class="home-button" href="/access">Access Gateway</a>
        <a class="home-button" href="/contact">Contact</a>
    </div>
</section>
