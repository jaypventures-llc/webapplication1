@page "/asset-preview"

<PageTitle>JPV-OS Asset Preview</PageTitle>

<section class="asset-preview-page">
    <div class="asset-preview-header">
        <p class="eyebrow">JPV-OS Asset Registry</p>
        <h1>Production Asset Preview</h1>
        <p>
            This page verifies that approved public assets are wired correctly through the centralized AssetPaths service.
        </p>
    </div>

    <div class="asset-grid">
        <article class="asset-card">
            <img src="@AssetPaths.Init.Hero" alt="init interface hero" />
            <h2>init</h2>
        </article>

        <article class="asset-card">
            <img src="@AssetPaths.JpvOs.Hero" alt="JPV-OS interface hero" />
            <h2>JPV-OS</h2>
        </article>

        <article class="asset-card">
            <img src="@AssetPaths.JayPVentures.Hero" alt="jaypventures hero" />
            <h2>jaypventures</h2>
        </article>

        <article class="asset-card">
            <img src="@AssetPaths.JayPVenturesLlc.Hero" alt="JayPVentures LLC hero" />
            <h2>JayPVentures LLC</h2>
        </article>

        <article class="asset-card">
            <img src="@AssetPaths.JayPVLabs.Hero" alt="jaypVLabs hero" />
            <h2>jaypVLabs</h2>
        </article>

        <article class="asset-card">
            <img src="@AssetPaths.JayPVLabs.InstituteHero" alt="JPV Institute hero" />
            <h2>JPV Institute</h2>
        </article>

        <article class="asset-card wide">
            <img src="@AssetPaths.References.EcosystemBoard" alt="Approved brand logos" />
            <h2>Design Reference</h2>
        </article>
    </div>
</section>

