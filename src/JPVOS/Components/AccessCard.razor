<a class="access-card" href="@Href">
    <span aria-label="Environment type">@Environment</span>
    <strong>@Title</strong>
    <p>@Description</p>
</a>

@code {
    [Parameter] public string Environment { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string Href { get; set; } = "/checkout-not-configured";
}
