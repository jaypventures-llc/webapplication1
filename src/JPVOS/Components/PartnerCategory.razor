<section class="partner-category">
    <div class="partner-info">
        <span class="partner-label">@Label</span>
        <h2>@Title</h2>
        <p>@Description</p>
    </div>

    <div class="partner-grid">
        @foreach (var partner in Partners)
        {
            <div class="partner-tile">
                @if (!string.IsNullOrWhiteSpace(partner.Icon))
                {
                    <img src="@partner.Icon" alt="@partner.Name" />
                }
                else
                {
                    <span class="partner-tile-mark" aria-hidden="true">@partner.Initials</span>
                }
                <span>@partner.Name</span>
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public PartnerItem[] Partners { get; set; } = [];
}
