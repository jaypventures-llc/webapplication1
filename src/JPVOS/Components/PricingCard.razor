
<article class="pricing-card">
    <p class="card-eyebrow">@Eyebrow</p>
    <h3>@Name</h3>
    <div class="price-line">
        <strong>@(BillingInterval == "annual" ? AnnualPrice : MonthlyPrice)</strong>
        <span>@(BillingInterval == "annual" ? "annual" : "monthly")</span>
    </div>
    <p>@Description</p>
    <div class="feature-list">
        @foreach (var feature in Features)
        {
            <span>@feature</span>
        }
    </div>
    <button class="button primary" @onclick="OnCheckout" disabled="@IsDisabled">@Cta</button>
</article>

@code {
    [Parameter] public string Eyebrow { get; set; } = "";
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string[] Features { get; set; } = [];
    [Parameter] public int MonthlyPrice { get; set; }
    [Parameter] public int AnnualPrice { get; set; }
    [Parameter] public string BillingInterval { get; set; } = "monthly";
    [Parameter] public string PackageKey { get; set; } = "";
    [Parameter] public bool IsDisabled { get; set; } = false;
    [Parameter] public EventCallback OnCheckout { get; set; };
    [Parameter] public string Cta { get; set; } = "Get init";
    
    // Alternative properties for simpler billing models
    [Parameter] public string Price { get; set; } = "";
    [Parameter] public string Term { get; set; } = "";
    [Parameter] public string Href { get; set; } = "/checkout-not-configured";
}

