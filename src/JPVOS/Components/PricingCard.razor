<article class="pricing-card">
    <p class="card-eyebrow">@Eyebrow</p>
    <h3>@Name</h3>
    <div class="price-line">
        <strong>@Price</strong>
        <span>@Term</span>
    </div>
    <p>@Description</p>
    <div class="feature-list">
        @foreach (var feature in Features)
        {
            <span>@feature</span>
        }
    </div>
    @if (!string.IsNullOrWhiteSpace(CheckoutUrl) && CheckoutUrl != "/checkout-not-configured")
    {
        <a href="@CheckoutUrl" class="button primary" target="_blank" rel="noopener noreferrer">@Cta</a>
    }
    else if (IsDisabled)
    {
        <button class="button primary" disabled>@Cta</button>
    }
    else
    {
        <button class="button primary" disabled>Checkout not configured</button>
    }
</article>

@code {
    [Parameter] public string Eyebrow { get; set; } = "";
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public string Price { get; set; } = "";
    [Parameter] public string Term { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string[] Features { get; set; } = [];
    [Parameter] public bool IsDisabled { get; set; } = false;
    [Parameter] public string CheckoutUrl { get; set; } = "/checkout-not-configured";
    [Parameter] public string Cta { get; set; } = "Get init";
}
