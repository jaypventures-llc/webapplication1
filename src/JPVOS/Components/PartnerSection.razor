<section class="partner-category">
    <h3 class="partner-section-label">@Title</h3>
    <div class="partner-grid" role="list">
        @ChildContent
    </div>
</section>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
